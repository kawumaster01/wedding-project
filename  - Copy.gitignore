            font-size: 2em;
            color: gold;
        }
        .guest-gallery {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
        }
        .gallery-item {
            margin: 10px;
            width: 150px;
            height: 150px;
            border-radius: 10px;
            overflow: hidden;
            border: 5px solid gold;
        }
        .wish-form {
            text-align: center;
            margin-top: 20px;
        }
        .modal {
            display: none;
            position: fixed;
            z-index: 1;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
